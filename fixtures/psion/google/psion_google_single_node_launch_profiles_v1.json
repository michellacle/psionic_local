      "declared_run_cost_ceiling_usd": 25.0,
      "startup_policy_overrides": {
        "pre_training_command": "cargo build -p psionic-train --example psion_google_plugin_host_native_accelerated_run",
        "training_command": "\"$CARGO_TARGET_DIR/debug/examples/psion_google_plugin_host_native_accelerated_run\" \"$PSION_OUTPUT_DIR\"",
        "post_training_archive_command": "bash \"$PSION_REPO_DIR/scripts/psion-google-archive-plugin-conditioned-run.sh\" --stem psion_plugin_host_native_accelerated --manifest-out \"$PSION_SCRATCH_DIR/psion_google_checkpoint_archive_manifest.json\" \"$PSION_OUTPUT_DIR\"",
