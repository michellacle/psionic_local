      "trainer_lane_id": "psion_plugin_host_native_accelerated",
      "expected_execution_backend": "cuda",
      "input_package_descriptor_uri": "gs://openagentsgemini-psion-train-us-central1/manifests/psion_google_plugin_host_native_accelerated_input_package_v1.json",
      "machine_type": "g2-standard-8",
      "accelerator_type": "nvidia-l4",
