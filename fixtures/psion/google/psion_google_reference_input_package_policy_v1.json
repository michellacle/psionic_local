{
  "schema_version": "psion.google_reference_input_package_policy.v1",
  "policy_id": "openagentsgemini-psion-google-reference-inputs-v1",
  "bucket_url": "gs://openagentsgemini-psion-train-us-central1",
  "descriptor_uri": "gs://openagentsgemini-psion-train-us-central1/manifests/psion_google_reference_input_package_v1.json",
  "archive_prefix": "gs://openagentsgemini-psion-train-us-central1/runs/staging/input_packages",
  "package_id_prefix": "psion-google-reference-inputs",
  "materialization": {
    "mode": "stage_to_local_disk_overlay_repo",
    "max_local_working_set_gb": 4,
    "overlay_target": "repo_clone"
