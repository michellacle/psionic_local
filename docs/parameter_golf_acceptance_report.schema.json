{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openagents.dev/psionic/parameter_golf_acceptance_report.schema.json",
  "title": "Psionic Parameter Golf Acceptance Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_path",
    "runner",
    "report_posture",
    "claim_vocabulary_version",
    "current_claim_posture",
    "accounting_posture",
    "selected_categories",
    "categories",
    "report_digest"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "schema_path": {
      "type": "string",
      "const": "docs/parameter_golf_acceptance_report.schema.json"
    },
    "runner": {
      "type": "string",
      "const": "scripts/check-parameter-golf-acceptance.sh"
    },
    "report_posture": {
      "type": "string",
      "enum": [
        "tracking_only"
      ]
    },
    "claim_vocabulary_version": {
      "type": "string",
      "minLength": 1
    },
    "current_claim_posture": {
      "type": "string",
      "enum": [
        "research",
        "non_record_submission",
        "record_candidate_blocked_on_accounting",
        "record_ready"
      ]
    },
    "accounting_posture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_cap_bytes",
        "artifact_cap_unit",
        "counted_components",
        "rust_runtime_posture",
        "wrapper_posture",
        "build_dependency_posture",
        "offline_evaluation_required"
      ],
      "properties": {
        "artifact_cap_bytes": {
          "type": "integer",
          "const": 16000000
        },
        "artifact_cap_unit": {
          "type": "string",
          "const": "decimal_bytes"
        },
        "counted_components": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "string",
            "enum": [
              "entrypoint_code_bytes",
              "compressed_model_bytes",
              "shipped_runtime_code_bytes",
              "shipped_wrapper_code_bytes",
              "required_build_dependency_bytes"
            ]
          }
        },
        "rust_runtime_posture": {
          "type": "string",
          "enum": [
            "must_count_when_shipped"
          ]
        },
        "wrapper_posture": {
          "type": "string",
          "enum": [
            "allowed_only_when_counted_and_challenge_compatible"
          ]
        },
        "build_dependency_posture": {
          "type": "string",
          "enum": [
            "not_exempt_by_default"
          ]
        },
        "offline_evaluation_required": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "selected_categories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "challenge-oracle-parity",
          "single-device-trainer-parity",
          "distributed-throughput-closure",
          "packaging-readiness",
          "record-track-readiness"
        ]
      }
    },
    "categories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/category"
      }
    },
    "report_digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  },
  "$defs": {
    "category": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "category_id",
        "matrix_status",
        "issue_refs",
        "green_definition",
        "current_repo_truth",
        "boundary_note"
      ],
      "properties": {
        "category_id": {
          "type": "string",
          "enum": [
            "challenge-oracle-parity",
            "single-device-trainer-parity",
            "distributed-throughput-closure",
            "packaging-readiness",
            "record-track-readiness"
          ]
        },
        "matrix_status": {
          "type": "string",
          "enum": [
            "implemented",
            "implemented_early",
            "partial",
            "partial_outside_psionic",
            "planned"
          ]
        },
        "issue_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "green_definition": {
          "type": "string",
          "minLength": 1
        },
        "current_repo_truth": {
          "type": "string",
          "minLength": 1
        },
        "boundary_note": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
